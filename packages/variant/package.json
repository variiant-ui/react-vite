{
  "name": "@variiant-ui/react-vite",
  "version": "0.2.2",
  "description": "Vite plugin that enables parallel React component explorations without modifying app source code. The swap boundary lives in the toolchain — app imports never change.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/variiant-ui/react-vite.git"
  },
  "homepage": "https://github.com/variiant-ui/react-vite#readme",
  "bugs": {
    "url": "https://github.com/variiant-ui/react-vite/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "vite",
    "components",
    "variants",
    "design-systems",
    "design-iteration",
    "ui"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  },
  "bin": {
    "variiant": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "vite": ">=5"
  },
  "dependencies": {
    "html-to-image": "^1.11.13"
  }
}
